# ============================================
# AI Knowledge Centre - Environment Variables
# ============================================
# Copy this file to .env and fill in strong random values.
# NEVER commit .env to version control.
#
# Generate secrets: python scripts/gen_secrets.py

# Server Configuration
SERVER_IP=192.168.1.100

# PostgreSQL
POSTGRES_DB=knowledge_centre
POSTGRES_USER=kcadmin
POSTGRES_PASSWORD=CHANGE_ME_strong_password_20chars_min

# MinIO
MINIO_USER=minioadmin
MINIO_PASSWORD=CHANGE_ME_strong_password_20chars_min

# JWT (generate a 64-char hex string, e.g. openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_64_char_hex_string_here_please_generate_random

# OpenWebUI
WEBUI_SECRET_KEY=CHANGE_ME_64_char_hex_string_here_please_generate_random

# Admin Panel
ADMIN_SECRET=CHANGE_ME_admin_panel_password

# Langfuse
LANGFUSE_SECRET_KEY=CHANGE_ME_random_string
LANGFUSE_PUBLIC_KEY=CHANGE_ME_random_string
LANGFUSE_SALT=CHANGE_ME_random_string

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20

# Alert Webhook (optional — e.g. Slack, Teams, custom endpoint)
# Sends JSON payloads on ingestion failures, retries, and RAGAS eval errors.
ALERT_WEBHOOK_URL=

# Query Cache TTL (seconds) — identical questions skip re-computation
# Default: 3600 (1 hour). Set to 0 to disable caching.
QUERY_CACHE_TTL=3600

# Grafana
GRAFANA_PASSWORD=CHANGE_ME_grafana_admin_password
